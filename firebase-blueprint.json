{
  "entities": {
    "Trade": {
      "title": "Trade",
      "description": "A record of a completed trade for strategy analysis.",
      "type": "object",
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO timestamp of the trade."
        },
        "score": {
          "type": "number",
          "description": "Strategy score at the time of trade."
        },
        "gamma": {
          "type": "number",
          "description": "Gamma value at the time of trade."
        },
        "oi_bias": {
          "type": "number",
          "description": "OI Bias value at the time of trade."
        },
        "trap": {
          "type": "boolean",
          "description": "Whether a trap was detected."
        },
        "pnl": {
          "type": "number",
          "description": "Profit or loss from the trade."
        },
        "win": {
          "type": "boolean",
          "description": "Whether the trade was a win."
        },
        "bias": {
          "type": "string",
          "enum": ["BULLISH", "BEARISH"],
          "description": "The trade direction bias."
        },
        "mode": {
          "type": "string",
          "description": "The strategy mode used (e.g., MOMENTUM_SNIPER)."
        },
        "vix": {
          "type": "number",
          "description": "VIX at entry."
        },
        "spot": {
          "type": "number",
          "description": "Spot price at entry."
        },
        "strike": {
          "type": "number",
          "description": "ATM strike established at entry."
        },
        "isExpiryDay": {
          "type": "boolean",
          "description": "Whether it was an expiry day."
        },
        "duration": {
          "type": "number",
          "description": "Trade duration in seconds."
        },
        "buyPrice": {
          "type": "number",
          "description": "Total entry cost for buy legs."
        },
        "sellPrice": {
          "type": "number",
          "description": "Total entry credit for sell legs."
        },
        "intelligence": {
          "type": "object",
          "description": "Derived strategy parameters (SL, Target, ATR, etc)."
        }
      },
      "required": [
        "timestamp",
        "score",
        "pnl",
        "win",
        "mode"
      ]
    }
  },
  "firestore": {
    "/trades/{tradeId}": {
      "schema": "Trade",
      "description": "Collection of all executed trades."
    }
  }
}
